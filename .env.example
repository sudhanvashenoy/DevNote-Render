# Copy this file to .env (or set these as real environment variables on your
# server/host) before running in production. Without JWT_SECRET / VAULT_KEY
# set, the app will refuse to start when NODE_ENV=production.

NODE_ENV=production
PORT=3333

# Generate strong random values, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
VAULT_KEY=

# Your real domain(s), comma-separated if you have more than one
# (e.g. https://app.example.com,https://www.example.com).
# Leave unset only for local development.
ALLOWED_ORIGIN=https://yourdomain.com

# Set to 1 if you're running behind a reverse proxy (nginx, Caddy, etc.)
# terminating HTTPS in front of this app.
TRUST_PROXY=1

# ── Optional: only needed on hosts with an EPHEMERAL filesystem
# (e.g. Render's free tier, which has no persistent disk). These let the
# app reconnect to Google Drive and auto-restore your data on every cold
# start, instead of losing the connection when local files get wiped.
# Leave all three blank if you have a persistent disk (Render paid plan,
# Oracle Cloud, etc.) — the normal in-app "Connect Google Drive" flow
# on the Sync page is all you need there.
#
# How to get these values: run the app locally once, connect Google Drive
# normally through the Sync page, then open data/sync-config.json and copy
# clientId / clientSecret / refreshToken from there into the variables below.
GDRIVE_CLIENT_ID=
GDRIVE_CLIENT_SECRET=
GDRIVE_REFRESH_TOKEN=
